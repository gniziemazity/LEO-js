{
	"name": "leo",
	"version": "1.0.0",
	"description": "Live-coding Assistant for Teachers",
	"author": "Radu Mariescu-Istodor <gniziemazity@gmail.com>",
	"main": "src/main/main.js",
	"scripts": {
		"start": "electron .",
		"build": "electron-builder",
		"time": "node lesson_tools/open.js timeline.html",
		"sim": "node lesson_tools/open.js simulator.html",
		"diff": "node lesson_tools/open.js differentiator.html",
		"grades": "node lesson_tools/open.js overview.html",
		"grades-analyze": "python lesson_tools/analyze_grades.py",
		"grades-start": "python lesson_tools/analyze_grades.py && node lesson_tools/open.js overview.html",
		"students": "node lesson_tools/open.js students.html anon=name",
		"students-full": "node lesson_tools/open.js students.html",
		"students-anon": "node lesson_tools/open.js students.html anon=id",
		"main": "python lesson_tools/main.py",
		"main-anon": "python lesson_tools/main.py --anon",
		"main-ideal": "python lesson_tools/main.py --follow-basis=ideal",
		"main-required": "python lesson_tools/main.py --follow-basis=required",
		"main-anon-ideal": "python lesson_tools/main.py --anon --follow-basis=ideal",
		"main-anon-required": "python lesson_tools/main.py --anon --follow-basis=required",
		"main-all": "python lesson_tools/main_all.py",
		"main-all-anon": "python lesson_tools/main_all.py --anon",
		"main-all-ideal": "python lesson_tools/main_all.py --follow-basis=ideal",
		"main-all-required": "python lesson_tools/main_all.py --follow-basis=required",
		"main-all-anon-ideal": "python lesson_tools/main_all.py --anon --follow-basis=ideal",
		"main-all-anon-required": "python lesson_tools/main_all.py --anon --follow-basis=required",
		"inspect": "python lesson_tools/inspect_dataset.py",
		"inspect-anon": "python lesson_tools/inspect_dataset.py --exclude-pii",
		"manifest": "python lesson_tools/build_manifest.py",
		"charts": "python lesson_tools/charts.py",
		"eval": "python lesson_tools/compare_methods_to_ideal.py",
		"overview": "python lesson_tools/build_overview.py",
		"test": "npm run test:py && npm run test:js",
		"test:py": "cd lesson_tools && python -m unittest discover -v",
		"test:js": "node --test tests/*.test.js"
	},
	"build": {
		"appId": "com.leo-js.app",
		"productName": "LEO-js",
		"icon": "src/shared/icon.ico",
		"files": [
			"**/*",
			"!node_modules/.cache"
		],
		"directories": {
			"output": "dist"
		}
	},
	"dependencies": {
		"@computer-use/nut-js": "^4.2.0",
		"express": "^5.2.1",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"electron": "^40.0.0",
		"electron-builder": "^26.4.0"
	}
}
