{
	"name": "leo",
	"version": "1.0.0",
	"description": "Live-coding Assistant for Teachers",
	"author": "Radu Mariescu-Istodor <gniziemazity@gmail.com>",
	"main": "src/main/main.js",
	"scripts": {
		"start": "electron .",
		"build": "electron-builder",
		"dash": "node lesson_tools/open.js dashboard.html",
		"sim": "node lesson_tools/open.js simulator.html",
		"diff": "node lesson_tools/open.js differentiator.html",
		"diff-lcs": "node lesson_tools/open.js differentiator.html mode=token-lcs",
		"diff-myers": "node lesson_tools/open.js differentiator.html mode=line-myers",		"diff-intraline": "node lesson_tools/open.js differentiator.html mode=intra-line",		"grades": "node lesson_tools/open.js grades-dashboard.html",
		"grades-analyze": "py lesson_tools/analyze_grades.py",
		"grades-start": "py lesson_tools/analyze_grades.py && node lesson_tools/open.js grades-dashboard.html",
		"students": "node lesson_tools/open.js students.html anon=name",
		"students-full": "node lesson_tools/open.js students.html",
		"students-anon": "node lesson_tools/open.js students.html anon=id",
		"main": "py lesson_tools/main.py --extra-star",
		"main-no-star": "py lesson_tools/main.py",
		"charts": "py lesson_tools/charts.py",
		"test": "npm run test:py && npm run test:js",
		"test:py": "cd lesson_tools && python -m unittest discover -v",
		"test:js": "node --test tests/*.test.js"
	},
	"build": {
		"appId": "com.leo-js.app",
		"productName": "LEO-js",
		"icon": "src/shared/icon.ico",
		"files": [
			"**/*",
			"!node_modules/.cache"
		],
		"directories": {
			"output": "dist"
		}
	},
	"dependencies": {
		"@computer-use/nut-js": "^4.2.0",
		"express": "^5.2.1",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"electron": "^40.0.0",
		"electron-builder": "^26.4.0"
	}
}
