{
	"name": "leo",
	"version": "1.0.0",
	"description": "Live-coding Assistant for Teachers",
	"author": "Radu Mariescu-Istodor <gniziemazity@gmail.com>",
	"main": "src/main/main.js",
	"scripts": {
		"start": "electron .",
		"build": "electron-builder",
		"dash": "node lesson_tools/open.js dashboard.html",
		"sim": "node lesson_tools/open.js simulator.html",
		"diff": "node lesson_tools/open.js differentiator.html",
		"students": "node lesson_tools/open.js students.html",
		"students-name": "node lesson_tools/open.js students.html anon=name",
		"students-id": "node lesson_tools/open.js students.html anon=id",
		"students-anon": "node lesson_tools/open.js students.html anon=id",
		"main": "py lesson_tools/main.py",
		"main-ci": "py lesson_tools/main.py --case-insensitive",
		"main-star": "py lesson_tools/main.py --extra-star",
		"test": "cd lesson_tools && python -m unittest test_reconstruction -v"
	},
	"build": {
		"appId": "com.leo-js.app",
		"productName": "LEO-js",
		"icon": "src/shared/icon.ico",
		"files": [
			"**/*",
			"!node_modules/.cache"
		],
		"directories": {
			"output": "dist"
		}
	},
	"dependencies": {
		"@computer-use/nut-js": "^4.2.0",
		"express": "^5.2.1",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"electron": "^40.0.0",
		"electron-builder": "^26.4.0"
	}
}
