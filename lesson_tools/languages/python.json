{
	"id": "python",
	"extensions": [".py"],
	"comments": {
		"line": "#",
		"block": null,
		"detectRe": "#[^\\n]*"
	},
	"strings": [
		{ "open": "\"\"\"", "close": "\"\"\"", "multiline": true },
		{ "open": "'''", "close": "'''", "multiline": true },
		{ "open": "\"", "close": "\"", "escape": "\\" },
		{ "open": "'", "close": "'", "escape": "\\" }
	],
	"keywords": [
		"def",
		"class",
		"return",
		"if",
		"elif",
		"else",
		"for",
		"while",
		"in",
		"not",
		"and",
		"or",
		"is",
		"None",
		"True",
		"False",
		"import",
		"from",
		"as",
		"with",
		"try",
		"except",
		"finally",
		"raise",
		"pass",
		"break",
		"continue",
		"yield",
		"lambda",
		"global",
		"nonlocal",
		"async",
		"await"
	],
	"builtins": [
		"print",
		"len",
		"range",
		"dict",
		"list",
		"tuple",
		"set",
		"str",
		"int",
		"float",
		"bool",
		"input",
		"open",
		"map",
		"filter",
		"sorted",
		"reversed",
		"enumerate",
		"zip",
		"sum",
		"min",
		"max",
		"abs",
		"round",
		"type",
		"isinstance"
	],
	"identifierRe": "[A-Za-z_][A-Za-z0-9_]*",
	"numberRe": "\\d+\\.?\\d*",
	"indent": {
		"increaseAfter": ":\\s*(#.*)?$",
		"decreaseOnLine": "^\\s*(elif|else|except|finally)\\b",
		"decreaseAfter": "^\\s*(break|continue|pass|raise|return)\\b"
	}
}
